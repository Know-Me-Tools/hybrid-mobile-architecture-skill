+# --- Leaves (C-007): frb 2.12 mobile FFI, Tauri 2 plugin, wasm-bindgen surface ---
+# flutter_rust_bridge already declared above (used by gen_gui_ffi).
+# Tauri 2 plugin framework. Native-only ŌĆö wasm/ios/android targets either don't
+# build tauri-plugin-gen-ui or build it as a no-op (see per-crate target gates).
+tauri             = { version = "2", default-features = false }
+tauri-plugin-role = "2"
+# wasm-bindgen surface (gen_gui_wasm). All are wasm32-safe.
+wasm-bindgen           = "0.2"
+wasm-bindgen-futures   = "0.4"
+js-sys                 = "0.3"
+serde-wasm-bindgen     = "0.6"
+# Required by gen_gui_ffi for the bus + stream forwarders (broadcast channel).
+[target.'cfg(not(target_arch = "wasm32"))'.dependencies]
+tokio = { workspace = true, features = ["rt-multi-thread", "sync", "macros"] }
+
 # Feature-unification pin (cargo-hakari): all real crates depend on this so a
 # switch between desktop/mobile/wasm invocations doesn't churn shared deps.
 # Regenerate with: cargo hakari generate
