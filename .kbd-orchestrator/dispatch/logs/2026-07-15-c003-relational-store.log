+    #[error("seed bundle {name} has an empty IPFS CID")]
+    EmptyCid { name: String },
+    #[error("sync attach failed: {0}")]
+    Sync(String),
+    #[cfg(feature = "pglite")]
+    #[error("embedded PGlite failed: {0}")]
+    Pglite(#[from] pglite_oxide::PgliteError),
+    #[cfg(feature = "pglite")]
+    #[error("embedded PGlite server failed: {0}")]
