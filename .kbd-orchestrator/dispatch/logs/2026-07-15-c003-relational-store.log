+    Pglite(#[from] pglite_oxide::PgliteError),
+    #[cfg(feature = "pglite")]
+    #[error("embedded PGlite server failed: {0}")]
+    PgliteServer(#[from] anyhow::Error),
+}
+
+pub type RelationalResult<T> = Result<T, RelationalError>;
