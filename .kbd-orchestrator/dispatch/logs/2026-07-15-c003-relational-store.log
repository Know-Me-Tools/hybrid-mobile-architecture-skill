+        });
+        let options = SqliteConnectOptions::from_str(&format!("sqlite://{}", path.as_ref().display()))?
+            .create_if_missing(true)
+            .foreign_keys(true);
+        let pool = SqlitePoolOptions::new().max_connections(1).connect_with(options).await?;
+        Ok(Self { pool })
+    }
