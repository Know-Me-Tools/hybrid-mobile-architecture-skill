+//! Mobile SQLite store. sqlite-vec is registered before any SQLx connection opens.
+
+use std::{path::Path, str::FromStr, sync::Once};
+
+use sqlx::{SqlitePool, sqlite::{SqliteConnectOptions, SqlitePoolOptions}};
