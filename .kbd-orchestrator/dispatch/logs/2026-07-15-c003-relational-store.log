+    async fn fetch(&self, client: &reqwest::Client, url: &str) -> RelationalResult<String> {
+        let bytes = client
+            .get(url)
+            .header(reqwest::header::IF_NONE_MATCH, format!("\"{}-{}\"", self.name, self.version))
+            .send()
+            .await
+            .and_then(reqwest::Response::error_for_status)
