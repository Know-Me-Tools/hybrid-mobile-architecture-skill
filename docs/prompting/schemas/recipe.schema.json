{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://know-me-tools.github.io/hybrid-mobile-architecture-skill/schemas/recipe.schema.json",
  "title": "Prometheus scenario recipe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "scenario",
    "harnesses",
    "required_skills",
    "recommended_roles",
    "authority",
    "artifacts",
    "evidence",
    "recovery",
    "termination",
    "prompts"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^scenario-[a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "scenario": {"type": "string", "minLength": 1},
    "harnesses": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^harness-[a-z0-9-]+$"}
    },
    "required_skills": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "recommended_roles": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string", "pattern": "^role-[a-z0-9-]+$"}
    },
    "authority": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^authority-[a-z0-9-]+$"}
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^artifact-[a-z0-9-]+$"}
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^evidence-[a-z0-9-]+$"}
    },
    "recovery": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^recovery-[a-z0-9-]+$"}
    },
    "termination": {"type": "string", "minLength": 1},
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prerequisites",
        "discovery",
        "feynman",
        "kbd_assess",
        "kbd_analyze",
        "kbd_spec",
        "kbd_plan",
        "research",
        "implementation",
        "public_boundary_verification",
        "independent_critic",
        "reflection_retention",
        "recovery",
        "stop_conditions"
      ],
      "properties": {
        "prerequisites": {"type": "string", "minLength": 1},
        "discovery": {"type": "string", "minLength": 1},
        "feynman": {"type": "string", "minLength": 1},
        "kbd_assess": {"type": "string", "minLength": 1},
        "kbd_analyze": {"type": "string", "minLength": 1},
        "kbd_spec": {"type": "string", "minLength": 1},
        "kbd_plan": {"type": "string", "minLength": 1},
        "research": {"type": "string", "minLength": 1},
        "implementation": {"type": "string", "minLength": 1},
        "public_boundary_verification": {"type": "string", "minLength": 1},
        "independent_critic": {"type": "string", "minLength": 1},
        "reflection_retention": {"type": "string", "minLength": 1},
        "recovery": {"type": "string", "minLength": 1},
        "stop_conditions": {"type": "string", "minLength": 1}
      }
    }
  }
}
