{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://know-me-tools.github.io/hybrid-mobile-architecture-skill/schemas/harness.schema.json",
  "title": "Prometheus harness playbook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "verified_at",
    "freshness_days",
    "official_sources",
    "required_sections",
    "instruction_sources",
    "skills",
    "mcp",
    "permissions",
    "autonomy",
    "evidence_capture",
    "handoff",
    "recovery",
    "public_boundary_verification"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^harness-[a-z0-9-]+$"},
    "name": {"type": "string", "minLength": 1},
    "verified_at": {"type": "string", "format": "date"},
    "freshness_days": {"type": "integer", "minimum": 1},
    "official_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "accessed_at", "supports"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "url": {"type": "string", "pattern": "^https://"},
          "accessed_at": {"type": "string", "format": "date"},
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "local_observations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_sections": {
      "type": "array",
      "minItems": 8,
      "items": {
        "enum": [
          "installation_version_checks",
          "instruction_discovery",
          "skills_plugins",
          "mcp_configuration",
          "permissions",
          "plan_build_critic",
          "autonomous_budgets",
          "evidence_capture",
          "interruption_resume",
          "handoff_examples"
        ]
      }
    },
    "instruction_sources": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "skills": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "mcp": {"type": "string", "minLength": 1},
    "permissions": {"type": "string", "minLength": 1},
    "autonomy": {"type": "string", "minLength": 1},
    "evidence_capture": {"type": "string", "minLength": 1},
    "handoff": {"type": "string", "minLength": 1},
    "recovery": {"type": "string", "minLength": 1},
    "public_boundary_verification": {"type": "string", "minLength": 1}
  }
}
