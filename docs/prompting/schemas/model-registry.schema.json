{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://know-me-tools.github.io/hybrid-mobile-architecture-skill/schemas/model-registry.schema.json",
  "title": "Prometheus model registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verified_at", "disclaimer", "freshness_policy", "requested_inventory", "models"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 2},
    "verified_at": {"type": "string", "format": "date"},
    "disclaimer": {"type": "string", "minLength": 1},
    "freshness_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_age_days", "refresh_required_before_production_routing"],
      "properties": {
        "max_age_days": {"type": "integer", "minimum": 1},
        "refresh_required_before_production_routing": {"type": "boolean"}
      }
    },
    "requested_inventory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requested_label", "registry_status"],
        "properties": {
          "requested_label": {"type": "string", "minLength": 1},
          "canonical_model_id": {"type": "string", "minLength": 1},
          "canonical_family": {"type": "string", "minLength": 1},
          "registry_status": {"enum": ["supported_exact", "supported_family", "unverified", "unavailable"]},
          "evidence_gap": {"type": "string"}
        },
        "anyOf": [
          {"required": ["canonical_model_id"]},
          {"required": ["canonical_family"]},
          {"required": ["evidence_gap"]}
        ]
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/model"}
    }
  },
  "$defs": {
    "httpsUrl": {
      "type": "string",
      "pattern": "^https://"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "accessed_at", "publisher", "official"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "url": {"$ref": "#/$defs/httpsUrl"},
        "accessed_at": {"type": "string", "format": "date"},
        "publisher": {"type": "string", "minLength": 1},
        "official": {"type": "boolean"}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "source_ids", "confidence"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "summary": {"type": "string", "minLength": 1},
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
        },
        "vendor_reported": {"type": "boolean", "default": false},
        "confidence": {"enum": ["high", "medium", "low", "unsupported"]}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model_id",
        "model_id_kind",
        "model_family",
        "verified_at",
        "official_sources",
        "sources",
        "claims",
        "context_window",
        "modalities",
        "tool_use",
        "reasoning_modes",
        "recommended_roles",
        "known_constraints",
        "availability",
        "confidence"
      ],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "model_id_kind": {"enum": ["exact", "family", "requested_alias"]},
        "model_family": {"type": "string", "minLength": 1},
        "requested_aliases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "verified_at": {"type": "string", "format": "date"},
        "official_sources": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/httpsUrl"}
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/source"}
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/claim"}
        },
        "context_window": {
          "anyOf": [{"type": "integer", "minimum": 1}, {"type": "null"}]
        },
        "modalities": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["text", "image", "audio", "video"]}
        },
        "tool_use": {"type": "boolean"},
        "reasoning_modes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "recommended_roles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "known_constraints": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "availability": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["high", "medium", "low", "unsupported"]}
      }
    }
  }
}
